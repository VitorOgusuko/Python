#verificar se a resposta é INT ou não
def leiaint(msg):
    while True:
        try:
            n = int(input(msg))
        except (ValueError, TypeError):
            print('\033[31mERRO, por favor, Tente Novamente\033[m')
            continue
        except Exception as error:
            print(f'\033[31mERRO: {error.__cause__}\033[m')
            continue
        except KeyboardInterrupt:
            print('\033[31mNenhum numero foi digitado\033[m')
            break
        else:
            return n


#verificar se a resposta é STR ou não
def leiastr(msg):
    while True:
        try:
            n = str(input(msg)).title().strip()
        except (ValueError, TypeError):
            print('\033[31mERRO, por favor, Tente Novamente\033[m')
            continue
        except KeyboardInterrupt:
            print('\033[31mNenhum numero foi digitado\033[m')
            continue
        except Exception as error:
            print(f'\033[31mERRO: {error.__cause__}\033[m')
            continue
        else:
            return n


