#linha com -
def linha(tam=40):
    return '-' * tam


#linha com =
def linha2(tam=40):
    return '=' *tam


#menu inicial com linha =
def menu1(txt, cor=5):
    print(fundo[cor], end='')
    print(linha2())
    print(txt.center(40))
    print(linha2())
    print(fundo[0], end='')


